<Window x:Class="FeintCommand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="FeintCommand - FeintAI Launcher"
        Width="1420"
        Height="860"
        MinWidth="980"
        MinHeight="660"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        KeyDown="Window_KeyDown"
        SourceInitialized="Window_SourceInitialized">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="224" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="46" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="4" Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                        <TextBlock Text="FC" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="FEINTCOMMAND" Margin="9,0,0,0" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="FeintAI launcher and command center" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="16,0" />
                <Button Grid.Column="2" Content="&#xE921;" FontFamily="Segoe Fluent Icons" Style="{StaticResource GhostButton}" Padding="0" MinHeight="0" Click="Minimize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" AutomationProperties.Name="Minimize" />
                <Button Grid.Column="3" Content="&#xE922;" FontFamily="Segoe Fluent Icons" Style="{StaticResource GhostButton}" Padding="0" MinHeight="0" Click="Maximize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" AutomationProperties.Name="Maximize or restore" />
                <Button Grid.Column="4" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons" Style="{StaticResource GhostButton}" Padding="0" MinHeight="0" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" AutomationProperties.Name="Close" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="224" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="20,26,20,22">
                        <TextBlock Text="F E I N T" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="AI OPERATIONS" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="1,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1">
                        <RadioButton x:Name="DashboardNav" GroupName="Navigation" IsChecked="True" Style="{StaticResource NavButton}" Tag="Dashboard" Checked="Navigate_Click" AutomationProperties.Name="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons" FontSize="15" Width="28" />
                                <TextBlock Text="Dashboard" FontWeight="SemiBold" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Navigation" Style="{StaticResource NavButton}" Tag="Programs" Checked="Navigate_Click" AutomationProperties.Name="Programs">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons" FontSize="15" Width="28" />
                                <TextBlock Text="Programs" FontWeight="SemiBold" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Navigation" Style="{StaticResource NavButton}" Tag="Settings" Checked="Navigate_Click" AutomationProperties.Name="Settings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="15" Width="28" />
                                <TextBlock Text="Settings" FontWeight="SemiBold" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Margin="20,0,20,24">
                        <Border Style="{StaticResource CardStyle}" Background="{DynamicResource SurfaceAltBrush}" Padding="14">
                            <StackPanel>
                                <TextBlock Text="FEINTCOMMAND" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="Launcher preview" FontSize="12" Margin="0,4,0,0" />
                                <TextBlock Text="v0.1.0" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid x:Name="DashboardView">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="34,30,34,42">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="F E I N T C O M M A N D" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="One command center for every FeintAI application." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="1,6,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Refresh status" Style="{StaticResource SecondaryButton}" Click="Refresh_Click" VerticalAlignment="Center" AutomationProperties.HelpText="Recheck configured commands and running processes" />
                            </Grid>

                            <Border Style="{StaticResource CardStyle}" Margin="0,24,0,28" Padding="22,18">
                                <UniformGrid Columns="4">
                                    <StackPanel>
                                        <TextBlock Text="PROGRAMS" Style="{StaticResource SectionLabel}" Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding ProgramCount}" FontSize="20" FontWeight="Bold" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="CONFIGURED" Style="{StaticResource SectionLabel}" Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding ConfiguredCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="RUNNING" Style="{StaticResource SectionLabel}" Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding RunningCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="LAUNCH TARGETS" Style="{StaticResource SectionLabel}" Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding TargetCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Margin="0,5,0,0" />
                                    </StackPanel>
                                </UniformGrid>
                            </Border>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FEINTAI PROGRAMS" Style="{StaticResource SectionLabel}" FontSize="13" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="+ Add program" Style="{StaticResource GhostButton}" Foreground="{DynamicResource AccentBrush}" Click="AddProgram_Click" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Programs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel IsItemsHost="True" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="344" MinHeight="260" Style="{StaticResource CardStyle}" Margin="0,0,16,16" Padding="20">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="42" Height="42" CornerRadius="8" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{Binding AccentBrush}" BorderThickness="1">
                                                        <TextBlock Text="F" Foreground="{Binding AccentBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="13,0,8,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="Bold" Margin="0,4,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsConfigured}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Content="&#xE712;" FontFamily="Segoe Fluent Icons" Style="{StaticResource GhostButton}" Padding="8" MinHeight="0" Click="EditProgram_Click" AutomationProperties.Name="Edit program" />
                                                </Grid>
                                                <TextBlock Grid.Row="1" Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,16,0,16" MinHeight="38" />
                                                <ItemsControl Grid.Row="2" ItemsSource="{Binding Targets}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding Name}" Style="{StaticResource SecondaryButton}" BorderBrush="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}" Margin="0,0,0,8" HorizontalContentAlignment="Left" Click="LaunchTarget_Click" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Button Grid.Row="3" Content="Open folder" Style="{StaticResource GhostButton}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left" Padding="0,8" Click="OpenProgramFolder_Click" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,18,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="QUICK ACTIONS" Style="{StaticResource SectionLabel}" Margin="0,0,0,14" />
                                        <UniformGrid Columns="3">
                                            <Button Content="Config folder" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenConfigFolder_Click" />
                                            <Button Content="launcher.json" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenConfiguration_Click" />
                                            <Button Content="Project folder" Style="{StaticResource SecondaryButton}" Click="OpenProjectFolder_Click" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="RECENT ACTIVITY" Style="{StaticResource SectionLabel}" Margin="0,0,0,12" />
                                        <ItemsControl ItemsSource="{Binding Activities}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="64" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding TimeText}" Foreground="{DynamicResource TextMutedBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ProgramsView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="34,30,34,42">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="PROGRAMS" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="Manage applications and their launchable components." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                                </StackPanel>
                                <Button Content="+ Add program" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="AddProgram_Click" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Programs}" Margin="0,26,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{Binding AccentBrush}" CornerRadius="4" />
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                    <TextBlock Text="TARGETS" Style="{StaticResource SectionLabel}" Foreground="{DynamicResource TextMutedBrush}" />
                                                    <TextBlock Text="{Binding Targets.Count}" FontSize="16" FontWeight="Bold" Margin="0,3,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="Edit" Width="90" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="EditProgram_Click" />
                                                    <Button Content="Remove" Width="90" Style="{StaticResource DangerButton}" Click="RemoveProgram_Click" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="SettingsView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="34,30,34,42" MaxWidth="900" HorizontalAlignment="Left">
                            <TextBlock Text="SETTINGS" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Text="Appearance, data, and project information." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,24" />

                            <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="Follow Windows or choose a FeintCommand theme." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <ComboBox x:Name="ThemeCombo" Grid.Column="1" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" SelectionChanged="ThemeCombo_SelectionChanged" AutomationProperties.Name="Color theme" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Launcher configuration" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ConfigurationPath}" FontFamily="Cascadia Mono, Consolas" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,7,0,16" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Open launcher.json" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="OpenConfiguration_Click" />
                                        <Button Content="Open containing folder" Style="{StaticResource SecondaryButton}" Click="OpenConfigFolder_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Product direction" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="This launcher keeps program definitions separate from process execution. That boundary is intentional: future Feint modules can move in-process behind the same profiles and navigation without discarding the dashboard." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,7,0,0" LineHeight="21" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" BorderBrush="{DynamicResource DangerBrush}" Padding="22">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Reset launcher profiles" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="Restore the three starter FeintAI entries. This replaces the current launcher configuration." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Reset profiles" Style="{StaticResource DangerButton}" VerticalAlignment="Center" Click="ResetDefaults_Click" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextMutedBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" VerticalAlignment="Center" Margin="9,0,0,0" />
                <TextBlock Grid.Column="2" Text="Ctrl+N add program  |  F5 refresh" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
