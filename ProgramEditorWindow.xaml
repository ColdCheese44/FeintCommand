<Window x:Class="FeintCommand.ProgramEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Feint program"
        Width="860"
        Height="680"
        MinWidth="760"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="28,22">
            <StackPanel>
                <TextBlock Text="PROGRAM PROFILE" Style="{StaticResource SectionLabel}" />
                <TextBlock Text="Configure the app and every component FeintCommand can launch." Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" MinHeight="310" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Program name" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,7" />
                        <TextBox Text="{Binding DraftProgram.Name, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Program name" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Description" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,7" />
                        <TextBox Text="{Binding DraftProgram.Description, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Program description" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Accent" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,7" />
                        <ComboBox ItemsSource="{Binding AccentOptions}" SelectedItem="{Binding DraftProgram.AccentColor}" AutomationProperties.Name="Program accent color">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="12" Height="12" Fill="{Binding}" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="LAUNCH TARGETS" Style="{StaticResource SectionLabel}" Margin="4,2,0,12" />
                            <ListBox x:Name="TargetsList" Grid.Row="1" ItemsSource="{Binding Targets}" DisplayMemberPath="Name" AutomationProperties.Name="Launch targets" />
                            <Grid Grid.Row="2" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Add" Style="{StaticResource SecondaryButton}" Click="AddTarget_Click" />
                                <Button Grid.Column="2" Content="Remove" Style="{StaticResource DangerButton}" Click="RemoveTarget_Click" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="22" DataContext="{Binding ElementName=TargetsList, Path=SelectedItem}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="TARGET DETAILS" Style="{StaticResource SectionLabel}" Margin="0,0,0,16" />
                            <TextBlock Grid.Row="1" Text="Button label" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,7" />
                            <TextBox Grid.Row="2" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Launch target name" />
                            <TextBlock Grid.Row="3" Text="Command, executable, script, folder, or URL" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,16,0,7" />
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Launch command" />
                                <Button Grid.Column="2" Content="Browse..." Style="{StaticResource SecondaryButton}" Click="BrowseCommand_Click" />
                            </Grid>
                            <Grid Grid.Row="5" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Arguments (optional)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,7" />
                                    <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Launch arguments" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Working directory" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,7" />
                                    <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Working directory" />
                                </StackPanel>
                                <Button Grid.Column="4" Margin="0,26,0,0" Content="Folder..." Style="{StaticResource SecondaryButton}" Click="BrowseFolder_Click" />
                            </Grid>
                            <TextBlock Grid.Row="6" x:Name="ValidationText" Foreground="{DynamicResource DangerBrush}" Margin="0,16,0,0" TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="0,1,0,0" Padding="28,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="100" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,10,0" />
                <Button Content="Save profile" Width="130" Style="{StaticResource PrimaryButton}" Click="Save_Click" IsDefault="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
